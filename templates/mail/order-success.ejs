<%
    const formatPrice = (price) => {
        return new Intl.NumberFormat('vi-VN', {
            style: 'currency',
            currency: 'VND'
        }).format(Number(price) || 0);
    };

    const itemsHtml = (locals.order.items || [])
        .map((item) => {
            return `
                <tr>
                    <td style="padding: 12px 0; border-bottom: 1px dashed #e5e7eb; width: 72px;">
                        <img src="${item.image}" alt="${item.name}" style="width: 64px; height: 64px; object-fit: cover; border-radius: 6px; border: 1px solid #e5e7eb;" />
                    </td>
                    <td style="padding: 12px 12px; border-bottom: 1px dashed #e5e7eb; vertical-align: top;">
                        <div style="font-weight: 600; color: #111827;">${item.name}</div>
                        <div style="font-size: 12px; color: #6b7280; margin-top: 4px;">SKU: ${item.sku}</div>
                    </td>
                    <td style="padding: 12px 8px; border-bottom: 1px dashed #e5e7eb; text-align: right; color: #374151;">${formatPrice(item.price)}</td>
                    <td style="padding: 12px 8px; border-bottom: 1px dashed #e5e7eb; text-align: center; color: #374151;">${item.quantity}</td>
                    <td style="padding: 12px 0; border-bottom: 1px dashed #e5e7eb; text-align: right; color: #111827; font-weight: 600;">${formatPrice(item.total)}</td>
                </tr>
            `;
        })
        .join('');

    const bodyContent = `
        <h2 style="color: #111827; margin-top: 0;">Cảm ơn bạn đã đặt hàng</h2>

        <p>Xin chào ${locals.order.ownerName},</p>
        <p>Chúng tôi đã tiếp nhận thành công đơn hàng <strong>#${locals.order.code}</strong> của bạn.</p>

        <div style="background-color: #f8fafc; border: 1px solid #e5e7eb; border-radius: 8px; padding: 18px; margin: 20px 0;">
            <h3 style="margin: 0 0 10px; color: #111827; font-size: 16px;">Thông tin người đặt</h3>
            <p style="margin: 6px 0; color: #374151;"><strong>Họ tên:</strong> ${locals.order.ownerName}</p>
            <p style="margin: 6px 0; color: #374151;"><strong>Email:</strong> ${locals.order.ownerEmail}</p>
            <p style="margin: 6px 0; color: #374151;"><strong>Số điện thoại:</strong> ${locals.order.ownerPhone || '-'}</p>
        </div>

        <div style="background-color: #f8fafc; border: 1px solid #e5e7eb; border-radius: 8px; padding: 18px; margin: 20px 0;">
            <h3 style="margin: 0 0 10px; color: #111827; font-size: 16px;">Địa chỉ giao hàng</h3>
            <p style="margin: 6px 0; color: #374151;"><strong>Người nhận:</strong> ${locals.order.shippingAddress.fullname}</p>
            <p style="margin: 6px 0; color: #374151;"><strong>Số điện thoại:</strong> ${locals.order.shippingAddress.phone || '-'}</p>
            <p style="margin: 6px 0; color: #374151;"><strong>Địa chỉ:</strong> ${locals.order.shippingAddress.street}, ${locals.order.shippingAddress.wardName}, ${locals.order.shippingAddress.districtName}, ${locals.order.shippingAddress.provinceName}</p>
        </div>

        <div style="margin: 24px 0;">
            <h3 style="margin: 0 0 12px; color: #111827; font-size: 16px;">Chi tiết đơn hàng</h3>
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr>
                        <th style="text-align: left; color: #6b7280; font-size: 12px; border-bottom: 1px solid #e5e7eb; padding-bottom: 8px;" colspan="2">Sản phẩm</th>
                        <th style="text-align: right; color: #6b7280; font-size: 12px; border-bottom: 1px solid #e5e7eb; padding-bottom: 8px;">Đơn giá</th>
                        <th style="text-align: center; color: #6b7280; font-size: 12px; border-bottom: 1px solid #e5e7eb; padding-bottom: 8px;">SL</th>
                        <th style="text-align: right; color: #6b7280; font-size: 12px; border-bottom: 1px solid #e5e7eb; padding-bottom: 8px;">Thành tiền</th>
                    </tr>
                </thead>
                <tbody>
                    ${itemsHtml}
                </tbody>
            </table>
        </div>

        <table style="width: 100%; border-collapse: collapse; margin-top: 16px;">
            <tr>
                <td style="padding: 6px 0; color: #6b7280;">Tổng tiền sản phẩm</td>
                <td style="padding: 6px 0; text-align: right; color: #111827; font-weight: 500;">${formatPrice(locals.order.totalProductAmount)}</td>
            </tr>
            <tr>
                <td style="padding: 6px 0; color: #6b7280;">Phí vận chuyển</td>
                <td style="padding: 6px 0; text-align: right; color: #111827; font-weight: 500;">${formatPrice(locals.order.shippingFee)}</td>
            </tr>
            <tr>
                <td style="padding: 6px 0; color: #6b7280;">Phương thức thanh toán</td>
                <td style="padding: 6px 0; text-align: right; color: #111827; font-weight: 500;">${locals.order.paymentMethodLabel}</td>
            </tr>
            <tr>
                <td style="padding: 10px 0; color: #111827; font-weight: 700; font-size: 16px; border-top: 1px solid #e5e7eb;">Tổng thanh toán</td>
                <td style="padding: 10px 0; text-align: right; color: #0f4c81; font-weight: 700; font-size: 18px; border-top: 1px solid #e5e7eb;">${formatPrice(locals.order.totalAmount)}</td>
            </tr>
        </table>

        ${
            locals.order.paymentMethod !== 'COD'
                ? `<p style="margin-top: 20px; color: #b45309; background: #fffbeb; border: 1px solid #fef3c7; padding: 12px; border-radius: 6px;">Nếu đơn hàng không được thanh toán trong vòng ${locals.paymentTtlHours} giờ, đơn sẽ tự động bị hủy.</p>`
                : ''
        }

        <div style="text-align: center; margin-top: 24px;">
            <a href="${locals.orderUrl}" style="display: inline-block; padding: 12px 24px; background-color: #111827; color: #ffffff; text-decoration: none; border-radius: 6px; font-weight: 600;">Xem đơn hàng</a>
        </div>

        <p style="margin-top: 24px; margin-bottom: 0;">Cảm ơn bạn đã mua sắm tại HaUI Fashion.</p>
    `;
%>

<%- await include('layouts/base', { body: bodyContent }) %>
