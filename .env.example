# App Configuration
SERVER_NAME=nest-app
NODE_ENV=development
PORT=3000
APP_CONTAINER_PORT=3000
APP_TIMEZONE=Asia/Ho_Chi_Minh

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://postgres:postgres@postgre:5432/nest_db?schema=public

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Network
NETWORK_NAME=haui-network

# JWT Configuration
JWT_SECRET=
JWT_EXPIRES_IN=86400
JWT_REFRESH_EXPIRES_IN=604800

# Mail Configuration
RESEND_API_KEY=
MAIL_FROM="No Reply <onboarding@resend.dev>"

# Docker Configuration
DOCKER_IMAGE=
DOCKER_TAG=

# Cloudinary Setup
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Gemini AI
GEMINI_API_KEY=
GEMINI_API_KEYS=
GEMINI_ULTIMATE_API_KEY=
GEMINI_ULTIMATE_ONLY=false
GEMINI_CHAT_MODEL=
GEMINI_IMAGE_MODEL=
GEMINI_EMBEDDING_MODEL=
GEMINI_GENERATION_MODEL=

# Product Embedding Sync
PRODUCT_EMBEDDING_TASK_TYPE=RETRIEVAL_DOCUMENT
EMBEDDING_SERVICE_URL=http://localhost:8000
EMBEDDING_SERVICE_TIMEOUT_MS=30000
PRODUCT_SEARCH_VECTOR_SEMANTIC_WEIGHT=0.75
PRODUCT_SEARCH_VECTOR_LEXICAL_WEIGHT=0.25
PRODUCT_SEARCH_VECTOR_MIN_SEMANTIC_SCORE=0.2
PRODUCT_SEARCH_VECTOR_RERANK_CANDIDATE_LIMIT=120
PRODUCT_SEARCH_VECTOR_RERANK_WEIGHT=0.55
PRODUCT_SEARCH_VECTOR_HYBRID_WEIGHT=0.45
PRODUCT_SEARCH_VECTOR_RERANK_TEXT_MAX_LENGTH=700
PRODUCT_SEARCH_VECTOR_DYNAMIC_THRESHOLD_MIN_SCORE=0.35
PRODUCT_SEARCH_VECTOR_DYNAMIC_THRESHOLD_TOP_RATIO=0.72
PRODUCT_SEARCH_VECTOR_DYNAMIC_THRESHOLD_MAX_DROP=0.28
PRODUCT_SEARCH_VECTOR_DYNAMIC_THRESHOLD_MIN_RESULTS=6

# HTTP Client
HTTP_CLIENT_TIMEOUT_MS=5000
HTTP_CLIENT_MAX_REDIRECTS=5
HTTP_CLIENT_MAX_SOCKETS=50

# VNPay Payment Gateway
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3000/orders

# SePay Payment Gateway
SEPAY_ENV=sandbox
SEPAY_MERCHANT_ID=
SEPAY_SECRET_KEY=
SEPAY_IPN_SECRET_KEY=
SEPAY_CHECKOUT_URL=https://pay-sandbox.sepay.vn/v1/checkout/init
SEPAY_API_BASE_URL=https://pgapi-sandbox.sepay.vn
SEPAY_RETURN_URL=http://localhost:3000/orders
SEPAY_IPN_URL=http://localhost:3000/api/v1/orders/sepay-ipn

# Debug Configuration (for local development)
DEBUG_PORT=
