generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  UNISEX
}

enum OrderStatus {
  PENDING
  PAID
  TO_DELIVERY
  DELIVERING
  COMPLETED
  CANCELED
}

enum PaymentMethod {
  COD
  VNPAY
  SEPAY
  MOMO
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum EmbeddingSyncStatus {
  PENDING
  SYNCED
  FAILED
}

enum ProductOptionType {
  COLOR
  SIZE
}
 
enum ChatMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model EntitySequence {
  key          String   @id
  currentValue Int      @default(0) @map("current_value")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("entity_sequences")
}

model User {
  id       String  @id @default(uuid())
  code     String  @unique
  username String  @unique
  fullname String
  email    String  @unique
  password String
  role     Role    @default(CUSTOMER)
  isActive Boolean @default(true) @map("is_active")
  isVerified Boolean @default(false) @map("is_verified")

  phone       String?
  dateOfBirth DateTime? @map("date_of_birth")
  gender      Gender?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  files     File[]
  addresses Address[]
  cart      Cart?
  orders    Order[]
  reviews   Review[]
  chatConversations ChatConversation[]

  @@map("users")
}

model File {
  id       String @id @default(uuid())
  filename String
  publicId String @map("public_id")
  url      String
  mimetype String
  size     Int

  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  productImages ProductImage[]

  @@index([userId])
  @@map("files")
}

model Category {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  description String?
  isActive    Boolean @default(true) @map("is_active")
  position    Int     @default(0)

  parentId String?    @map("parent_id")
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  products Product[]

  @@index([parentId])
  @@map("categories")
}

model Address {
  id           String  @id @default(uuid())
  fullname     String
  phone        String
  provinceId   Int?    @map("province_id")
  provinceName String  @map("province_name")
  districtId   Int?    @map("district_id")
  districtName String  @map("district_name")
  wardCode     String? @map("ward_code")
  wardName     String  @map("ward_name")
  street       String
  isDefault    Boolean @default(false) @map("is_default")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("addresses")
}

model Product {
  id   String @id @default(uuid())
  slug String @unique
  name String

  description     Json?
  descriptionHtml String? @map("description_html") @db.Text
  shortDescription String? @map("short_description") @db.Text

  brand           String?
  gender          Gender?
  styleTags       Json?   @map("style_tags")
  material        String?
  season          String?
  fit             String?

  isActive Boolean @default(true) @map("is_active")

  embeddingSyncStatus EmbeddingSyncStatus @default(PENDING) @map("embedding_sync_status")
  embeddingDirty      Boolean             @default(true) @map("embedding_dirty")
  embeddingContentHash String?            @map("embedding_content_hash")
  embeddingUpdatedAt  DateTime?           @map("embedding_updated_at")

  categoryId String? @map("category_id")
  category   Category? @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @default(now()) @map("updated_at")

  options  ProductOption[]
  variants Variant[]
  images   ProductImage[]

  reviews  Review[]
  embeddings ProductEmbedding[]

  @@index([categoryId])
  @@index([embeddingDirty, updatedAt])
  @@index([embeddingSyncStatus])
  @@map("products")
}

model ProductEmbedding {
  id               String              @id @default(uuid())

  productId        String              @map("product_id")
  product          Product             @relation(fields: [productId], references: [id], onDelete: Cascade)

  modelName        String              @map("model_name")
  summaryModel     String?             @map("summary_model")
  embeddingVector  Unsupported("vector") @map("embedding_vector")
  embeddingDim     Int                 @map("embedding_dim")
  embeddingInputText String            @map("embedding_input_text") @db.Text
  summaryText      String?             @map("summary_text") @db.Text
  semanticContext  String?             @map("semantic_context") @db.Text
  contentHash      String              @map("content_hash")
  status           EmbeddingSyncStatus @default(SYNCED)
  errorMessage     String?             @map("error_message") @db.Text
  lastEmbeddedAt   DateTime?           @map("last_embedded_at")
  isActive         Boolean             @default(true) @map("is_active")

  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  @@unique([productId, modelName], map: "product_embeddings_product_model_unique")
  @@index([productId, isActive])
  @@index([status])
  @@index([contentHash])
  @@map("product_embeddings")
}

model Review {
  id String @id @default(uuid())

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  star    Int
  content String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
  @@map("reviews")
}

model ProductImage {
  id String @id @default(uuid())

  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  fileId String @map("file_id")
  file   File   @relation(fields: [fileId], references: [id])

  optionValueId String? @map("option_value_id")
  optionValue   ProductOptionValue? @relation(fields: [optionValueId], references: [id])

  isPrimary Boolean @default(false) @map("is_primary")
  position  Int     @default(0)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@index([optionValueId])
  @@index([fileId])
  @@map("product_images")
}

model Variant {
  id String @id @default(uuid())

  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  colorOptionValueId String @map("color_option_value_id")
  colorOptionValue   ProductOptionValue @relation("VariantColorOptionValue", fields: [colorOptionValueId], references: [id])

  sizeOptionValueId String @map("size_option_value_id")
  sizeOptionValue   ProductOptionValue @relation("VariantSizeOptionValue", fields: [sizeOptionValueId], references: [id])

  sku   String  @unique
  price Decimal @db.Decimal(10, 2)
  stock Int     @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cartItems  CartItem[]
  orderItems OrderItem[]

  @@unique([productId, colorOptionValueId, sizeOptionValueId], map: "variants_product_color_size_unique")
  @@index([productId])
  @@index([colorOptionValueId])
  @@index([sizeOptionValueId])
  @@map("variants")
}

model ProductOption {
  id        String  @id @default(uuid())
  productId String  @map("product_id")

  name      ProductOptionType

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  values    ProductOptionValue[]

  @@index([productId])
  @@unique([productId, name])
  @@map("product_options")
}

model ProductOptionValue {
  id        String  @id @default(uuid())
  optionId  String  @map("option_id")

  value     String

  hexColor  String? @map("hex_color")

  option    ProductOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  images ProductImage[]

  colorVariants Variant[] @relation("VariantColorOptionValue")
  sizeVariants  Variant[] @relation("VariantSizeOptionValue")

  @@index([optionId])
  @@unique([optionId, value])
  @@map("product_option_values")
}

model Cart {
  id String @id @default(uuid())

  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items CartItem[]

  @@map("carts")
}

model CartItem {
  id String @id @default(uuid())

  cartId String @map("cart_id")
  cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)

  variantId String  @map("variant_id")
  variant   Variant @relation(fields: [variantId], references: [id])

  quantity Int @default(1)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([cartId, variantId])
  @@index([cartId])
  @@index([variantId])
  @@map("cart_items")
}

model Order {
  id   String @id @default(uuid())
  code String @unique

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  userSnapshot    Json @map("user_snapshot")
  shippingAddress Json @map("shipping_address")

  status      OrderStatus @default(PENDING)
  totalProductAmount Decimal @db.Decimal(10, 2) @map("total_product_amount")
  shippingFee Decimal @db.Decimal(10, 2) @map("shipping_fee")
  totalAmount Decimal     @db.Decimal(10, 2) @map("total_amount")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items   OrderItem[]
  payment Payment?

  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id String @id @default(uuid())

  orderId String @map("order_id")
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  variantId String  @map("variant_id")
  variant   Variant @relation(fields: [variantId], references: [id])

  productSnapshot Json    @map("product_snapshot")
  quantity        Int
  price           Decimal @db.Decimal(10, 2)

  @@index([orderId])
  @@index([variantId])
  @@map("order_items")
}

model Payment {
  id   String @id @default(uuid())
  code String @unique

  orderId String @unique @map("order_id")
  order   Order  @relation(fields: [orderId], references: [id])

  method PaymentMethod
  status PaymentStatus

  amount Decimal @db.Decimal(10, 2)

  providerTransactionId String? @map("provider_transaction_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("payments")
}

model ChatConversation {
  id        String  @id @default(uuid())
  sessionKey String @map("session_key")

  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  title      String?
  lastIntent String? @map("last_intent")
  metadata   Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  messages ChatMessage[]

  @@index([sessionKey, updatedAt])
  @@index([userId, updatedAt])
  @@map("chat_conversations")
}

model ChatMessage {
  id String @id @default(uuid())

  conversationId String           @map("conversation_id")
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role   ChatMessageRole
  intent String?
  content String @db.Text

  toolCalls      Json? @map("tool_calls")
  productPayload Json? @map("product_payload")
  metadata       Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([conversationId, createdAt])
  @@map("chat_messages")
}
