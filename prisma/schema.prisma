generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  UNISEX
}

enum OrderStatus {
  PENDING
  PAID
  TO_DELIVERY
  DELIVERING
  COMPLETED
  CANCELED
}

enum PaymentMethod {
  COD
  VNPAY
  MOMO
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

model EntitySequence {
  key          String   @id
  currentValue Int      @default(0) @map("current_value")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("entity_sequences")
}

model User {
  id       String  @id @default(uuid())
  code     String  @unique
  username String  @unique
  fullname String
  email    String  @unique
  password String
  role     Role    @default(CUSTOMER)
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  files     File[]
  addresses Address[]
  cart      Cart?
  orders    Order[]

  @@map("users")
}

model File {
  id       String @id @default(uuid())
  filename String
  publicId String @map("public_id")
  url      String
  mimetype String
  size     Int

  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  productImages ProductImage[]

  @@index([userId])
  @@map("files")
}

model Category {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  description String?
  isActive    Boolean @default(true) @map("is_active")
  position    Int     @default(0)

  parentId String?    @map("parent_id")
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  products Product[]

  @@index([parentId])
  @@map("categories")
}

model Address {
  id           String  @id @default(uuid())
  fullname     String
  phone        String
  provinceId   Int?    @map("province_id")
  provinceName String  @map("province_name")
  districtId   Int?    @map("district_id")
  districtName String  @map("district_name")
  wardCode     Int? @map("ward_code")
  wardName     String  @map("ward_name")
  street       String
  isDefault    Boolean @default(false) @map("is_default")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@map("addresses")
}

model Product {
  id   String @id @default(uuid())
  slug String @unique
  name String

  description     Json?
  descriptionHtml String? @map("description_html") @db.Text
  brand           String?
  gender          Gender?
  styleTags       Json?   @map("style_tags")
  material        String?
  season          String?
  fit             String?

  isActive Boolean @default(true) @map("is_active")

  categoryId String? @map("category_id")
  category   Category? @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  images   ProductImage[]
  variants Variant[]

  @@index([categoryId])
  @@map("products")
}

model ProductImage {
  id String @id @default(uuid())

  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  fileId String @map("file_id")
  file   File   @relation(fields: [fileId], references: [id])

  isPrimary Boolean @default(false) @map("is_primary")
  position  Int     @default(0)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@index([fileId])
  @@map("product_images")
}

model Variant {
  id String @id @default(uuid())

  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  size  String
  color String
  sku   String  @unique
  price Decimal @db.Decimal(10, 2)
  stock Int     @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([productId])
  @@map("variants")
}

model Cart {
  id String @id @default(uuid())

  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items CartItem[]

  @@map("carts")
}

model CartItem {
  id String @id @default(uuid())

  cartId String @map("cart_id")
  cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)

  variantId String  @map("variant_id")
  variant   Variant @relation(fields: [variantId], references: [id])

  quantity Int @default(1)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([cartId, variantId])
  @@index([cartId])
  @@index([variantId])
  @@map("cart_items")
}

model Order {
  id   String @id @default(uuid())
  code String @unique

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  userSnapshot    Json @map("user_snapshot")
  shippingAddress Json @map("shipping_address")

  status      OrderStatus @default(PENDING)
  totalAmount Decimal     @db.Decimal(10, 2) @map("total_amount")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items   OrderItem[]
  payment Payment?

  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id String @id @default(uuid())

  orderId String @map("order_id")
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  variantId String  @map("variant_id")
  variant   Variant @relation(fields: [variantId], references: [id])

  productSnapshot Json    @map("product_snapshot")
  quantity        Int
  price           Decimal @db.Decimal(10, 2)

  @@index([orderId])
  @@index([variantId])
  @@map("order_items")
}

model Payment {
  id   String @id @default(uuid())
  code String @unique

  orderId String @unique @map("order_id")
  order   Order  @relation(fields: [orderId], references: [id])

  method PaymentMethod
  status PaymentStatus

  amount Decimal @db.Decimal(10, 2)

  providerTransactionId String? @map("provider_transaction_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("payments")
}
