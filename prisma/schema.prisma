generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  ADMIN
}

model EntitySequence {
  key          String   @id
  currentValue Int      @default(0) @map("current_value")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("entity_sequences")
}

model User {
  id        String    @id @default(uuid())
  code      String?   @unique
  username  String    @unique
  name      String?   
  fullname  String
  email     String    @unique
  password  String
  role      Role      @default(CUSTOMER)
  isActive  Boolean   @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  files     File[]
  addresses Address[]

  @@map("users")
}

model File {
  id        String   @id @default(uuid())
  filename  String
  publicId  String   @map("public_id")
  url       String
  mimetype  String
  size      Int

  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  @@map("files")
}

model Category {
  id          String     @id @default(uuid())
  name        String
  slug        String     @unique
  description String?
  imageUrl    String?    @map("image_url")
  isActive    Boolean    @default(true) @map("is_active")
  position    Int        @default(0)

  parentId    String?    @map("parent_id")
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")

  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  deletedAt   DateTime?  @map("deleted_at")

  @@map("categories")
}

model Address {
  id            String   @id @default(uuid())
  fullName      String   @map("full_name")
  phone         String
  provinceId    Int?     @map("province_id")
  provinceName  String   @map("province_name")
  districtId    Int?     @map("district_id")
  districtName  String   @map("district_name")
  wardCode      String?  @map("ward_code")
  wardName      String   @map("ward_name")
  street        String
  isDefault     Boolean  @default(false) @map("is_default")

  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id])

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("addresses")
}
